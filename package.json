{
  "name": "dale-deal-backend",
  "version": "2.0.0",
  "description": "Backend API para el marketplace Dale Deal",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.17 <23"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "prototype": "node prototype-server.js",
    "proto": "node prototype-server.js",
    "db:schema": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/schema.sql",
    "db:seed": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/seed.sql",
    "db:migrate:payments": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/migrations/002_payments.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
