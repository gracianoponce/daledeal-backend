{
  "name": "dale-deal-backend",
  "version": "2.0.0",
  "description": "Backend API para el marketplace Dale Deal",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.17 <23"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "prototype": "node prototype-server.js",
    "proto": "node prototype-server.js",
    "db:schema": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/schema.sql",
    "db:seed": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/seed.sql",
    "db:migrate:payments": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/migrations/002_payments.sql",
    "db:migrate:google": "psql \"$(grep ^DATABASE_URL .env | cut -d= -f2-)\" -f db/migrations/007_google_oauth.sql"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "@sentry/node": "^8.55.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
