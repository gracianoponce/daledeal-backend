# ============================================================
# DALE DEAL — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto del servidor
PORT=3000

# URL del frontend (para CORS)
# En desarrollo: http://localhost:5500 o el puerto de tu live server
FRONTEND_URL=http://localhost:5500

# ============================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================
# Formato: postgresql://usuario:contraseña@host:puerto/basededatos
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/daledeal

# ============================================================
# JWT (JSON Web Tokens)
# ============================================================
# Generá un secret seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_este_valor_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ============================================================
# MERCADO PAGO
# ============================================================
# Cómo obtener credenciales TEST (sandbox, gratis):
#   1. Entrar a https://www.mercadopago.com.ar/developers/panel/app
#   2. Crear una aplicación (tipo "Checkout Pro")
#   3. Copiar el "Access Token de prueba" (empieza con TEST-)
#   4. Copiar la "Public Key de prueba"
#   5. Para el webhook: configurar la URL pública en el panel > Webhooks
#      y copiar el "Secret" que aparece ahí
#
# Tarjetas de test:
#   APRO 5031 7557 3453 0604 → aprobado
#   OTHE 5031 7557 3453 0604 → rechazo genérico
#   CONT 5031 7557 3453 0604 → pendiente
#   (CVV 123, vencimiento cualquiera futuro)
MP_ACCESS_TOKEN=TEST-000000000000000-000000-0000000000000000000000000000000-000000000
MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
MP_WEBHOOK_SECRET=

# Comisión del marketplace (0.05 = 5%)
MARKETPLACE_COMMISSION_RATE=0.05

# URLs públicas (necesarias para back_urls y notification_url)
# En desarrollo local con ngrok: https://xxxx.ngrok.io
APP_BASE_URL=http://localhost:3000

# ============================================================
# EMAIL TRANSACCIONAL (Resend)
# ============================================================
# Cómo obtener API key:
#   1. Ir a https://resend.com (free tier: 100 emails/día)
#   2. Crear cuenta + verificar dominio (daledeal.com.ar)
#   3. API Keys → Create → copiar valor (empieza con re_)
# Si dejás esta variable vacía, los emails se loggean a la consola
# pero no se envían (modo dev).
RESEND_API_KEY=
EMAIL_FROM=Dale Deal <hola@daledeal.com.ar>
EMAIL_REPLY_TO=
